# Supabase project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://lycokyqudsetqiaejlgr.supabase.co

# Publishable key (Supabase dashboard → API Keys → publishable / anon)
# Server-only in this app — do NOT prefix with NEXT_PUBLIC_
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Secret key (Supabase dashboard → API Keys → secret / service_role)
# Never expose this in the browser or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key
