{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:website",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": true,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/docutext/dist/**"
    }
  }
}
