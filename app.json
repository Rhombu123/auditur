{
  "expo": {
    "name": "Auditur",
    "slug": "auditur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "auditur",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.auditur.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Auditur scans VIN barcodes on vehicles.",
        "NSLocationWhenInUseUsageDescription": "Auditur pins scanned vehicles to your current GPS location on the lot."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#007C78"
      },
      "package": "com.auditur.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Auditur to scan VIN barcodes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Auditur to capture GPS when you scan a vehicle."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 96,
          "resizeMode": "contain",
          "backgroundColor": "#F4F7F5"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71109b37-95eb-4ac7-8b1d-ada84cd4f7df"
      }
    },
    "owner": "alkarakoolya"
  }
}
